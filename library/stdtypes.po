msgstr ""
"ਉਹਨਾਂ ਸਾਰੀਆਂ bases ਲਈ ``int(string, base)`` ਜੋ 2 ਦੀ power ਨਹੀਂ ਹਨ।"

#: ../../library/stdtypes.rst:6561
msgid "``str(integer)``."
msgstr "``str(integer)``।"

#: ../../library/stdtypes.rst:6562
msgid "``repr(integer)``."
msgstr "``repr(integer)``।"

#: ../../library/stdtypes.rst:6563
